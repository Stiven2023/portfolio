---
import { getTranslations } from '../i18n/translations';

const lang = Astro.currentLocale ?? 'es';
const t = getTranslations(lang).contact;
---

<section id="contacto" class="max-w-3xl mx-auto mt-12 p-6 rounded-xl border border-white/10 bg-white/5">
  <h3 class="text-white text-xl font-semibold">{t.title}</h3>
  <p class="text-gray-300 text-sm mt-2">{t.subtitle}</p>

  <form class="mt-4" name="contact" method="POST" data-netlify="true">
    <input type="hidden" name="form-name" value="contact">
    <div class="sr-only">
      <label>{t.botField}</label>
      <input name="bot-field" />
    </div>

    <label class="block mt-3">
      <span class="text-gray-200 text-sm">{t.nameLabel}</span>
      <input required name="name" type="text" class="mt-1 w-full rounded-md bg-neutral-900/60 border border-white/10 px-3 py-2 text-gray-100" placeholder={t.namePlaceholder} />
    </label>

    <label class="block mt-3">
      <span class="text-gray-200 text-sm">{t.emailLabel}</span>
      <input required name="email" type="email" class="mt-1 w-full rounded-md bg-neutral-900/60 border border-white/10 px-3 py-2 text-gray-100" placeholder={t.emailPlaceholder} />
    </label>

    <label class="block mt-3">
      <span class="text-gray-200 text-sm">{t.messageLabel}</span>
      <textarea required name="message" rows="5" class="mt-1 w-full rounded-md bg-neutral-900/60 border border-white/10 px-3 py-2 text-gray-100" placeholder={t.messagePlaceholder}></textarea>
    </label>

    <div class="flex items-center gap-3 mt-4">
      <button type="submit" class="bg-cyan-500 hover:bg-cyan-600 text-black font-semibold px-4 py-2 rounded">{t.send}</button>
      <a class="text-sm text-gray-300 underline" href="mailto:stivenalexis2005@gmail.com">{t.sendByEmail}</a>
      <a class="text-sm text-gray-300 underline" href="/HOJADEVIDASTIVEN.pdf_2025_7_24.pdf_2025_8_9.pdf" download>{t.downloadCV}</a>
    </div>
  </form>
</section>
