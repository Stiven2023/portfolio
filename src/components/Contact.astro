---
import { getTranslations } from '../i18n/translations';

const lang = Astro.currentLocale ?? 'es';
const t = getTranslations(lang).contact;
---

<section id="contacto" class="contact-box max-w-xl mx-auto mt-8 p-8 rounded-xl border border-white/10 bg-white/5 text-center">
  <h3 class="text-white text-2xl font-bold">{lang === 'es' ? '¿Trabajamos juntos?' : 'Work together?'}</h3>
  <p class="text-gray-400 text-sm mt-3 leading-relaxed max-w-sm mx-auto">
    {lang === 'es'
      ? 'Disponible para proyectos freelance y posiciones full-time. Respondo en menos de 24 horas.'
      : 'Available for freelance projects and full-time positions. I reply within 24 hours.'}
  </p>
  <div class="flex flex-wrap justify-center gap-3 mt-6">
    <a
      href="mailto:stivenalexis2005@gmail.com"
      class="px-5 py-2.5 rounded-lg bg-cyan-600 hover:bg-cyan-500 text-white text-sm font-semibold transition-colors"
    >
      stivenalexis2005@gmail.com
    </a>
    <a
      href="https://www.linkedin.com/in/stiven-aguirre-19436b211"
      target="_blank"
      rel="noopener"
      class="px-5 py-2.5 rounded-lg border border-white/20 text-white text-sm font-semibold hover:bg-white/10 transition-colors"
    >
      LinkedIn
    </a>
  </div>
</section>

<style>
  .contact-box {
    border-width: 0.5px;
  }
</style>
