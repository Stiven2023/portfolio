---
import { getTranslations } from '../i18n/translations';

const lang = Astro.currentLocale ?? 'es';
const t = getTranslations(lang).footer;
---

<footer class="w-full border-t border-white/[0.07] mt-8">
    <div class="flex items-center justify-between max-w-[740px] mx-auto px-4 sm:px-6 py-5 text-sm text-gray-500">
        <span>© {new Date().getFullYear()} Stiven Aguirre</span>
        <span>Bogotá, Colombia</span>
    </div>
</footer>
