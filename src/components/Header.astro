---
import { getTranslations } from '../i18n/translations';

const lang = Astro.currentLocale ?? 'es';
const t = getTranslations(lang);
const h = t.header;
---

<header class="flex justify-center items-center py-5 max-w-6xl w-full px-4 mx-auto">
    <nav class="flex flex-row flex-wrap gap-x-6 gap-y-2 text-sm sm:text-base opacity-80 justify-center">
        <a href="#top">{h.home}</a>
        <a href="#sobre-mi">{h.about}</a>
        <a href="#habilidades">{h.skills}</a>
        <a href="#experiencia">{h.experience}</a>
        <a href="#proyectos">{h.projects}</a>
        <a href="#contacto">{h.contact}</a>
        <a
            href={h.switchLangHref}
            class="ml-2 rounded border border-white/20 px-2 py-0.5 text-xs font-semibold tracking-wide hover:bg-white/10 transition"
            aria-label={lang === 'es' ? 'Switch to English' : 'Cambiar a Español'}
        >
            {h.switchLang}
        </a>
    </nav>
</header>
