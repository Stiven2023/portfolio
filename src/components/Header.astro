---
import { getTranslations } from '../i18n/translations';

const lang = Astro.currentLocale ?? 'es';
const t = getTranslations(lang);
const h = t.header;
---

<header id="site-header" class="sticky top-0 z-50 w-full border-b border-white/5 bg-[#131111]/80 backdrop-blur-[12px]">
    <div class="flex justify-between items-center py-3 max-w-[740px] w-full px-4 sm:px-6 mx-auto">
        <span class="text-sm font-semibold text-white/80 nav-logo">SA</span>
        <nav id="main-nav" class="flex flex-row flex-wrap gap-x-5 gap-y-2 text-sm opacity-80 justify-center nav-links">
            <a href="#top" data-section="top" class="nav-link hover:text-cyan-300 transition-colors">{h.home}</a>
            <a href="#sobre-mi" data-section="sobre-mi" class="nav-link hover:text-cyan-300 transition-colors">{h.about}</a>
            <a href="#habilidades" data-section="habilidades" class="nav-link hover:text-cyan-300 transition-colors">{h.skills}</a>
            <a href="#experiencia" data-section="experiencia" class="nav-link hover:text-cyan-300 transition-colors">{h.experience}</a>
            <a href="#proyectos" data-section="proyectos" class="nav-link hover:text-cyan-300 transition-colors">{h.projects}</a>
            <a href="#contacto" data-section="contacto" class="nav-link hover:text-cyan-300 transition-colors">{h.contact}</a>
        </nav>
        <a
            href={h.switchLangHref}
            class="rounded border border-white/20 px-2 py-0.5 text-xs font-semibold tracking-wide hover:bg-white/10 transition"
            aria-label={lang === 'es' ? 'Switch to English' : 'Cambiar a Español'}
        >
            {h.switchLang}
        </a>
    </div>
</header>

<script>
    const sections = document.querySelectorAll<HTMLElement>('section[id], main > *[id]');
    const navLinks = document.querySelectorAll<HTMLAnchorElement>('.nav-link');

    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    navLinks.forEach((link) => {
                        const section = link.dataset.section;
                        if (section && entry.target.id === section) {
                            navLinks.forEach((l) => l.classList.remove('text-cyan-300', 'opacity-100'));
                            link.classList.add('text-cyan-300', 'opacity-100');
                        }
                    });
                }
            });
        },
        { rootMargin: '-40% 0px -50% 0px', threshold: 0 }
    );

    sections.forEach((section) => observer.observe(section));
</script>

<style>
    @media (max-width: 600px) {
        .nav-links {
            display: none;
        }
    }
</style>
