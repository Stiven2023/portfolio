---
import HTMLIcon from "../icons/HTML.astro";
import CSSIcon from "../icons/CSS.astro";
import JavascriptIcon from "../icons/Javascript.astro";
import ReactIcon from "../icons/React.astro";
import NextjsIcon from "../icons/Nextjs.astro";
import TailwindIcon from "../icons/Tailwind.astro";
import NodejsIcon from "../icons/Nodejs.astro";
import TypescriptIcon from "../icons/Typescript.astro";
import MongoDBIcon from "../icons/MongoDB.astro";
import PHPIcon from "../icons/Php.astro";
import { getTranslations } from '../i18n/translations';

const lang = Astro.currentLocale ?? 'es';
const t = getTranslations(lang).projects;

const ICONS: Record<string, any> = {
    HTML: HTMLIcon,
    CSS: CSSIcon,
    JavaScript: JavascriptIcon,
    React: ReactIcon,
    "Next.js": NextjsIcon,
    Tailwind: TailwindIcon,
    "Node.js": NodejsIcon,
    TypeScript: TypescriptIcon,
    MongoDB: MongoDBIcon,
    PHP: PHPIcon,
};

const PROJECTS_WITH_ICONS = t.items.map((p) => ({
    ...p,
    tags: p.tags.map((tag) => ({ name: tag, Icon: ICONS[tag] || null })),
}));
---

<div class="projects-grid grid grid-cols-2 gap-4">
    {
        PROJECTS_WITH_ICONS.map(project => (
        <article class="project-card flex flex-col rounded-xl border border-white/10 bg-white/5 overflow-hidden hover:border-white/30 transition-[border-color] duration-150">
                <img
                    class="w-full h-[140px] object-cover bg-neutral-900/60"
                    loading="lazy"
                    src={project.image}
                    alt={`${t.screenshotAlt} ${project.title}`}
                />
                <div class="p-4 flex flex-col flex-1">
                    <h3 class="text-white font-bold text-sm line-clamp-2 leading-snug">{project.title}</h3>
                    <p class="text-gray-400 text-xs mt-2 line-clamp-2 leading-relaxed flex-1">{project.description}</p>
                    <ul class="mt-3 flex flex-wrap gap-1.5">
                        {project.tags.map(({ name, Icon }) => (
                            <li class="flex items-center gap-1 px-2 py-0.5 rounded-full border border-white/10 bg-neutral-900/60 text-gray-300 text-[10px]">
                              {Icon && <Icon class="w-3 h-3 shrink-0" />} {name}
                            </li>
                        ))}
                    </ul>
                </div>
            </article>
        ))
    }
</div>

<style>
    @media (max-width: 600px) {
        .projects-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
