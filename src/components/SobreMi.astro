---
import { getTranslations } from '../i18n/translations';

const lang = Astro.currentLocale ?? 'es';
const t = getTranslations(lang).about;
---

<section class="max-w-prose mx-auto text-center sm:text-left">
  <p class="text-gray-300 leading-relaxed text-pretty" set:html={t.intro} />
  <ul class="mt-5 space-y-2 text-gray-300">
    <li>• {t.strengthLabel} <span class="text-yellow-300">{t.strengthValue}</span>.</li>
    <li>• {t.workStyle}</li>
    <li>• {t.value}</li>
    <li>• <span set:html={t.qa} /></li>
  </ul>
</section>
