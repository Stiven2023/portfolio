---
import Header from '../components/Header.astro';
import '@fontsource/onest/400.css';
import '@fontsource/onest/600.css';
import Footer from '../components/Footer.astro';
import { getTranslations } from '../i18n/translations';

const lang = Astro.currentLocale ?? 'es';
const t = getTranslations(lang);
const canonicalURL = 'https://www.portafoliostivenaguirre.org/';
---

<!doctype html>
<html lang={t.layout.lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{t.layout.title}</title>
		<meta name="description" content={t.layout.description} />
		<link rel="canonical" href={canonicalURL} />
		<!-- Open Graph -->
		<meta property="og:title" content={t.layout.title} />
		<meta property="og:description" content={t.layout.description} />
		<meta property="og:image" content={`${canonicalURL}yop.jpg`} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:type" content="website" />
	</head>
	<body>
		<Header />
		<slot />
		<Footer />
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light dark;
	}

	html {
		background-color: #131111;
		font-family: system-ui, sans-serif;
		line-height: 1.5;
		scroll-behavior: smooth;
	}

	body {
		font-family: 'Onest', sans-serif;
		display: flex;
		flex-direction: column;	
		height: 100vh;
	}

	@media (prefers-reduce-motion: reduce) {
		html {
			scroll-behavior: auto;
		}
	}
	
</style>
